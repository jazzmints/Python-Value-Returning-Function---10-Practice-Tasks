#EXERCISE 3
def calculate_assets(liabilities, equity):
    return liabilities + equity

combined_assets = 0

for i in range(1, 4):
    print("Company", i)

    company = input("Enter company name: ")
    liabilities = float(input("Enter liabilities: "))
    equity = float(input("Enter equity: "))

    assets = calculate_assets(liabilities, equity)
    combined_assets += assets

    print(company)
    print("Assets =", assets)

print("Combined Assets =", combined_assets)

print(" ")