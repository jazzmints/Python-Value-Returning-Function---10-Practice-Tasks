#EXERCISE 3
def rectangle_area(length, width):
    return length * width

total_area = 0

for i in range(1, 4):
    print("Rectangle", i)

    length = float(input("Enter the length: "))
    width = float(input("Enter the width: "))

    area = rectangle_area(length, width)

    print("Rectangle", i, "Area =", area)

    total_area += area

print("Total Area =", total_area)

print(" ")