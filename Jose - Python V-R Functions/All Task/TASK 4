#EXERCISE 3
def weekly_pay(hours, rate):
    return hours * rate

grand_payroll = 0

for i in range(1, 4):
    name = input("Enter employee name: ")
    hours = float(input("Enter hours worked: "))
    rate = float(input("Enter hourly rate: "))

    pay = weekly_pay(hours, rate)
    grand_payroll += pay

    print(name, "= $", pay)

print("Grand Payroll = $", grand_payroll)

print(" ")